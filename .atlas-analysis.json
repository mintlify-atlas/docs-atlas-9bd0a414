  "keyFeatures": [
    "Multi-role user management (regular, expert, crowdsourcing, admin)",
    "Biographical data entry for Chinese historical figures",
    "Comprehensive relationship mapping (kinship, offices, associations)",
    "Public API for querying historical data",
    "Operations tracking and audit logging",
    "SQLite data export and sync to HuggingFace",
    "Advanced search and query capabilities",
    "Batch data upload and management tools"
  ],
  "publicApiSurface": [
    "/api/post_list - Query offices by category code",
    "/api/entry_list - Query entry paths by category",
    "/api/place_list - Search places by name and time period",
    "/api/place_belongs_to - Query hierarchical place relationships",
    "/api/office_list_by_name - Search offices by Chinese/English name",
    "/api/entry_list_by_name - Search entry paths by name",
    "/api/query_office_postings - Query office appointment records",
    "/api/query_entry_postings - Query entry path records",
    "/api/query_relatives_2 - Query kinship relationships",
    "/api/get_assoc - Get association types",
    "/api/find_assoc - Search associations by name",
    "/api/query_associates - Query social associations",
    "/api/query_assoc_network - Query social network with N-degree separation"
  ]
